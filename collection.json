{
  "info": {
    "name": "PokéAPI Collection",
    "description": "Full test collection for the Flask Pokémon Trainer API (INFO 2602)",
    "_postman_id": "poke-api-2602",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "token", "value": "", "type": "string" },
    { "key": "pokemon_id", "value": "1", "type": "string" },
    { "key": "user_pokemon_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ash\",\n  \"password\": \"pikachu123\"\n}"
            },
            "url": { "raw": "{{host}}/signup", "host": ["{{host}}"], "path": ["signup"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('token');",
                  "  pm.collectionVariables.set('token', json.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ash\",\n  \"password\": \"pikachu123\"\n}"
            },
            "url": { "raw": "{{host}}/login", "host": ["{{host}}"], "path": ["login"] }
          }
        },
        {
          "name": "Login — Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Has error', () => pm.expect(pm.response.json()).to.have.property('error'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ash\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": { "raw": "{{host}}/login", "host": ["{{host}}"], "path": ["login"] }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{host}}/logout", "host": ["{{host}}"], "path": ["logout"] }
          }
        }
      ]
    },
    {
      "name": "Pokémon Directory",
      "item": [
        {
          "name": "List All Pokémon",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has pokemon array', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('pokemon');",
                  "  pm.expect(json.pokemon).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{host}}/pokemon/?page=1&per_page=20",
              "host": ["{{host}}"],
              "path": ["pokemon", ""],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Search Pokémon",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Results match query', () => {",
                  "  const pokemon = pm.response.json().pokemon;",
                  "  pokemon.forEach(p => pm.expect(p.name.toLowerCase()).to.include('char'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{host}}/pokemon/?q=char",
              "host": ["{{host}}"],
              "path": ["pokemon", ""],
              "query": [{ "key": "q", "value": "char" }]
            }
          }
        },
        {
          "name": "Get Pokémon by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has name', () => pm.expect(pm.response.json()).to.have.property('name'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{host}}/pokemon/{{pokemon_id}}",
              "host": ["{{host}}"],
              "path": ["pokemon", "{{pokemon_id}}"]
            }
          }
        },
        {
          "name": "Get Pokémon — Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{host}}/pokemon/9999",
              "host": ["{{host}}"],
              "path": ["pokemon", "9999"]
            }
          }
        }
      ]
    },
    {
      "name": "My Pokémon (JWT Required)",
      "item": [
        {
          "name": "Get My Pokémon",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{host}}/mypokemon/", "host": ["{{host}}"], "path": ["mypokemon", ""] }
          }
        },
        {
          "name": "Catch a Pokémon",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has user_pokemon with id', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('user_pokemon');",
                  "  pm.collectionVariables.set('user_pokemon_id', json.user_pokemon.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pokemon_id\": 25,\n  \"name\": \"Pika-bro\"\n}"
            },
            "url": { "raw": "{{host}}/mypokemon/", "host": ["{{host}}"], "path": ["mypokemon", ""] }
          }
        },
        {
          "name": "Rename a Pokémon",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Name updated', () => pm.expect(pm.response.json().user_pokemon.name).to.equal('Sparky'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": {{user_pokemon_id}},\n  \"name\": \"Sparky\"\n}"
            },
            "url": { "raw": "{{host}}/mypokemon/", "host": ["{{host}}"], "path": ["mypokemon", ""] }
          }
        },
        {
          "name": "Release a Pokémon",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has released message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": {{user_pokemon_id}}\n}"
            },
            "url": { "raw": "{{host}}/mypokemon/", "host": ["{{host}}"], "path": ["mypokemon", ""] }
          }
        },
        {
          "name": "Catch without token — Should Fail",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401 or 422', () => {",
                  "  pm.expect([401, 422]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pokemon_id\": 1,\n  \"name\": \"NoAuth\"\n}"
            },
            "url": { "raw": "{{host}}/mypokemon/", "host": ["{{host}}"], "path": ["mypokemon", ""] }
          }
        }
      ]
    }
  ]
}


